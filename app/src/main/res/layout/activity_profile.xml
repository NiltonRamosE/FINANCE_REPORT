<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/backgroundPrimary">

    <!-- ── Top Bar ── -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/cardBackground"
        android:elevation="0dp"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="?attr/colorPrimary"
        app:title="Mi perfil"
        app:titleTextColor="?attr/textPrimary"
        app:titleTextAppearance="@style/TextAppearance.FINANCE_REPORT.Headline" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="?attr/colorOutlineVariant" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="28dp"
            android:paddingBottom="32dp">

            <!-- ── Avatar Section ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="24dp">

                <FrameLayout
                    android:id="@+id/flAvatarContainer"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:layout_gravity="center">

                    <!-- Avatar ring / initials -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cvAvatar"
                        android:layout_width="96dp"
                        android:layout_height="96dp"
                        app:cardCornerRadius="48dp"
                        app:cardBackgroundColor="?attr/badgeSecondaryBg"
                        app:cardElevation="0dp"
                        app:strokeColor="?attr/colorSecondary"
                        app:strokeWidth="2.5dp">

                        <ImageView
                            android:id="@+id/ivAvatar"
                            android:layout_width="96dp"
                            android:layout_height="96dp"
                            android:layout_gravity="center"
                            android:scaleType="centerCrop"
                            android:visibility="gone"
                            android:contentDescription="@string/avatar" />

                        <TextView
                            android:id="@+id/tvInitials"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="@string/initials"
                            android:textSize="32sp"
                            android:textStyle="normal"
                            android:textColor="?attr/colorPrimary"
                            android:fontFamily="sans-serif-medium" />

                        <ProgressBar
                            android:id="@+id/progressBar"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_gravity="center"
                            android:visibility="gone" />

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Edit badge (bottom-right) -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cvEditBadge"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="bottom|end"
                        android:layout_marginBottom="2dp"
                        android:layout_marginEnd="2dp"
                        app:cardCornerRadius="13dp"
                        app:cardBackgroundColor="?attr/colorPrimary"
                        app:cardElevation="2dp"
                        app:strokeColor="?attr/backgroundPrimary"
                        app:strokeWidth="2dp">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_edit"
                            android:contentDescription="@string/photo_edit"
                            app:tint="?attr/colorOnPrimary" />

                    </com.google.android.material.card.MaterialCardView>

                </FrameLayout>

                <!-- Name below avatar -->
                <TextView
                    android:id="@+id/tvFullName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/default_name"
                    android:textSize="18sp"
                    android:textStyle="normal"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="?attr/textPrimary" />

                <!-- Email below name -->
                <TextView
                    android:id="@+id/tvEmailSub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/default_email_user"
                    android:textSize="13sp"
                    android:textColor="?attr/textSecondary" />

            </LinearLayout>

            <!-- ── Información Personal Card ── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="?attr/cardBackground"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutlineVariant"
                app:strokeWidth="0.5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Card header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="20dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/personal_information"
                            android:textSize="11sp"
                            android:letterSpacing="0.08"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="?attr/colorPrimary" />

                        <!-- Edit pill button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnEditProfile"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="@string/edit"
                            android:textSize="13sp"
                            android:textAllCaps="false"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            app:backgroundTint="?attr/badgePrimaryBg"
                            android:textColor="?attr/textPrimary"
                            app:cornerRadius="20dp"
                            app:icon="@drawable/ic_edit"
                            app:iconSize="13dp"
                            app:iconGravity="textStart"
                            app:iconTint="?attr/textPrimary"
                            app:iconPadding="4dp"
                            app:elevation="0dp" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="?attr/colorOutlineVariant" />

                    <!-- Field: Nombre -->
                    <include layout="@layout/item_profile_field"
                        android:id="@+id/fieldNombre" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginStart="64dp"
                        android:background="?attr/colorOutlineVariant" />

                    <!-- Field: Apellido Paterno -->
                    <include layout="@layout/item_profile_field"
                        android:id="@+id/fieldApellidoPaterno" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginStart="64dp"
                        android:background="?attr/colorOutlineVariant" />

                    <!-- Field: Apellido Materno -->
                    <include layout="@layout/item_profile_field"
                        android:id="@+id/fieldApellidoMaterno" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginStart="64dp"
                        android:background="?attr/colorOutlineVariant" />

                    <!-- Field: Género -->
                    <include layout="@layout/item_profile_field"
                        android:id="@+id/fieldGenero" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginStart="64dp"
                        android:background="?attr/colorOutlineVariant" />

                    <!-- Field: Correo -->
                    <include layout="@layout/item_profile_field"
                        android:id="@+id/fieldEmail" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveProfile"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="16dp"
                android:text="@string/save_changes"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:visibility="gone"
                app:backgroundTint="?attr/colorPrimary"
                app:cornerRadius="14dp"
                app:icon="@drawable/ic_save"
                app:iconGravity="textStart"
                app:iconTint="?attr/colorOnPrimary"
                app:elevation="0dp" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>