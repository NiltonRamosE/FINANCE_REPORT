<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_navigation"
    app:startDestination="@id/nav_dashboard">

    <fragment
        android:id="@+id/nav_dashboard"
        android:name="com.nramos.finance_report.ui.dashboard.DashboardFragment"
        android:label="@string/dashboard"
        tools:layout="@layout/fragment_dashboard" />

    <fragment
        android:id="@+id/nav_reports"
        android:name="com.nramos.finance_report.ui.reports.ReportsFragment"
        android:label="@string/new_movement"
        tools:layout="@layout/fragment_reports" />

    <fragment
        android:id="@+id/nav_movements"
        android:name="com.nramos.finance_report.ui.movements.MovementsFragment"
        android:label="@string/my_movements"
        tools:layout="@layout/fragment_movements" />

    <fragment
        android:id="@+id/nav_statistics"
        android:name="com.nramos.finance_report.ui.statistics.StatisticsFragment"
        android:label="@string/statistics"
        tools:layout="@layout/fragment_statistics" />

    <fragment
        android:id="@+id/nav_management"
        android:name="com.nramos.finance_report.ui.management.ManagementFragment"
        android:label="Gestión"
        tools:layout="@layout/fragment_management" />

    <fragment
        android:id="@+id/nav_reminders"
        android:name="com.nramos.finance_report.ui.reminders.RemindersFragment"
        android:label="Recordatorios"
        tools:layout="@layout/fragment_reminders" />

</navigation>