<!-- res/values/themes.xml -->
<resources>
    <style name="Theme.FINANCE_REPORT" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- Colores de acento -->
        <item name="colorPrimary">@color/gold</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">@color/black</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorTertiary">@color/green</item>
        <item name="colorOnTertiary">@color/white</item>

        <!-- Errores -->
        <item name="colorError">@color/red</item>
        <item name="colorOnError">@color/white</item>

        <!-- Atributos personalizados - Claro -->
        <item name="backgroundPrimary">@color/white</item>
        <item name="backgroundSecondary">@color/gray_light</item>
        <item name="cardBackground">@color/white</item>

        <item name="textPrimary">@color/text_light_primary</item>
        <item name="textSecondary">@color/text_light_secondary</item>
        <item name="textTertiary">@color/text_light_tertiary</item>

        <item name="inputBackground">@color/white</item>
        <item name="inputStroke">@color/gray_medium</item>

        <item name="badgePrimaryBg">@color/gold</item>
        <item name="badgeSecondaryBg">@color/gray_light</item>

        <item name="accentColor">@color/gold</item>
        <item name="accentColorSecondary">@color/green</item>

        <!-- Material compatibilidad -->
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/text_light_primary</item>
        <item name="colorOutline">@color/gray_medium</item>
        <item name="colorOutlineVariant">@color/gray_light</item>
        <item name="android:colorBackground">@color/white</item>

        <!-- Tipografía -->
        <item name="textAppearanceDisplayLarge">@style/TextAppearance.FINANCE_REPORT.Display</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.FINANCE_REPORT.Headline</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.FINANCE_REPORT.Body</item>
        <item name="textAppearanceLabelSmall">@style/TextAppearance.FINANCE_REPORT.Label</item>
    </style>

    <!-- Estilos de texto -->
    <style name="TextAppearance.FINANCE_REPORT.Display" parent="TextAppearance.Material3.DisplayLarge">
        <item name="fontFamily">@font/playfair_display_bold</item>
        <item name="android:textSize">32sp</item>
    </style>

    <style name="TextAppearance.FINANCE_REPORT.Headline" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="fontFamily">@font/playfair_display_bold</item>
        <item name="android:textSize">22sp</item>
    </style>

    <style name="TextAppearance.FINANCE_REPORT.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">15sp</item>
        <item name="android:lineSpacingMultiplier">1.4</item>
    </style>

    <style name="TextAppearance.FINANCE_REPORT.Label" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.08</item>
    </style>

    <!-- Estilos de botones -->
    <style name="Widget.FINANCE_REPORT.Button.Google" parent="Widget.Material3.Button.ElevatedButton">
        <item name="android:backgroundTint">@color/white</item>
        <item name="android:textColor">@color/text_light_primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="elevation">2dp</item>
        <item name="rippleColor">@color/gray_light</item>
    </style>

    <style name="Widget.FINANCE_REPORT.Button.Social" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">12dp</item>
        <item name="strokeColor">?attr/colorOutlineVariant</item>
        <item name="android:textColor">?attr/textSecondary</item>
        <item name="iconTint">?attr/accentColor</item>
        <item name="android:gravity">center</item>
    </style>
</resources>